# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# Get your key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Local pgvector (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://b2meister:b2meister@localhost:5433/b2meister

# Ollama (embeddings always local; LLM fallback optional)
OLLAMA_HOST=http://localhost:11434

# Embedding model — multilingual, great for German
EMBED_MODEL=nomic-embed-text-v2-moe

# Default LLM — prefix "groq:" or "ollama:" to switch providers
DEFAULT_MODEL=groq:meta-llama/llama-4-scout-17b-16e-instruct
